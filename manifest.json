{
  "manifest_version": 3,
  "name": "Whatsapp Guardian - Session Watchdog",
  "short_name": "WA Guardian",
  "version": "1.0.0",
  "version_name": "1.0.0 Stable - Copyright ©2026 Thorsten Bylicki / BYLICKILABS. All rights reserved.",
  "description": "Browser extension for defensive WhatsApp Web session monitoring.",
  "homepage_url": "https://github.com/bylickilabs/whatsapp-guardian-session-watchdog",
  "minimum_chrome_version": "107",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WA Guardian - Session Watchdog",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}